#include <stdio.h>

int main() {
    int n = 5;
    for (int i = n; i >= 1; i -= 2) {
        int spasi = (n - i) / 2;
        for (int s = 0; s < spasi; s++) {
            printf(" ");
        }
        for (int j = 0; j < i; j++) {
            printf("*");
        }
        printf("\n");
    }
    for (int i = 3; i <= n; i += 2) {
        int spasi = (n - i) / 2;
        for (int s = 0; s < spasi; s++) {
            printf(" ");
        }
        for (int j = 0; j < i; j++) {
            printf("*");
        }
        printf("\n");
    }
    return 0;
}
