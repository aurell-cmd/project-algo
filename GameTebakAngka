#include <stdio.h>
#include <stdlib.h>
#include <time.h>

int main() {
    int secret, guess, attempts = 0;

    srand(time(NULL)); 
    secret = rand() % 10 + 1; 

    printf("Game Tebak Angka (1-10)\n");

    do {
        printf("Masukkan tebakan Anda: ");
        if (scanf("%d", &guess) !=1) {
            printf("Input tidak valid, coba lagi!\n");
            while (getchar() != '\n');
            continue;
        }
        attempts++;

        if (guess < secret) {
            printf("Tebakan terlalu kecil!\n");
        } else if (guess > secret) {
            printf("Tebakan terlalu besar!\n");
        } else {
            printf("Selamat, tebakan Anda benar!\n");
            printf("Jumlah percobaan: %d kali\n", attempts);
        }
    } while (guess != secret);

    return 0;
}
