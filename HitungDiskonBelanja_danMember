#include <stdio.h>

int main() {
    int total_belanja;
    float total_bayar, diskon;
    char member;

    printf("Masukkan total belanja: ");
    scanf("%d", &total_belanja);

    printf("Apakah mempunyai kartu member? (Y/T): ");
    scanf(" %c", &member);

    if (total_belanja >= 500000) {
        diskon = 0.20 * total_belanja;
    } else if (total_belanja >= 300000 && total_belanja < 500000) {
        diskon = 0.15 * total_belanja;
    } else if (total_belanja >= 100000 && total_belanja < 300000) {
        diskon = 0.10 * total_belanja;
    } else {
        diskon = 0;
    }

    total_bayar = total_belanja - diskon;

    if (member == 'Y' || member == 'y') {
        total_bayar = total_bayar - (0.05 * total_bayar);
    }

    printf("Total yang harus dibayar: Rp %.2f\n", total_bayar);

    return 0;
}
