#include <stdio.h>

int main() {
    int baris = 4;     
    char huruf = 'A';  
    for (int i = 1; i <= baris; i++) {
        for (int s = 1; s <= baris - i; s++) {
            printf(" ");
        }
        for (int j = 1; j <= i; j++) {
            printf("%c", huruf++);
        }
        printf("\n");
    }
    return 0;
}
