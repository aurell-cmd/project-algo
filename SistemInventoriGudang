#include <stdio.h>
#include <string.h>

#define JUMLAH_RAK 5
#define MAX_NAMA 50

void tampilkanMenu();
void tampilkanHistogram(char namaJenisBarang[][MAX_NAMA], int jumlahStok[]);
void tambahStok(int jumlahStok[], int nomorRak);
void kurangiStok(int jumlahStok[], int nomorRak);

int main() {
    char namaJenisBarang[JUMLAH_RAK][MAX_NAMA];
    int jumlahStok[JUMLAH_RAK] = {0};
    int pilihan, nomorRak;

    printf("=== SISTEM INVENTORI GUDANG TOSERBA ===\n\n");

    for (int i = 0; i < JUMLAH_RAK; i++) {
        printf("Masukkan nama jenis barang untuk Rak %d: ", i + 1);
        fgets(namaJenisBarang[i], sizeof(namaJenisBarang[i]), stdin);
        namaJenisBarang[i][strcspn(namaJenisBarang[i], "\n")] = 0;
    }

    do {
        tampilkanMenu();
        printf("Pilih menu: ");
        scanf("%d", &pilihan);
        getchar();

        switch (pilihan) {
            case 1:
                printf("\n=== TAMBAH STOK ===\n");
                for (int i = 0; i < JUMLAH_RAK; i++) {
                    printf("%d. %s (Stok: %d)\n", i + 1, namaJenisBarang[i], jumlahStok[i]);
                }
                printf("Pilih nomor rak: ");
                scanf("%d", &nomorRak);
                getchar();
                if (nomorRak >= 1 && nomorRak <= JUMLAH_RAK)
                    tambahStok(jumlahStok, nomorRak - 1);
                else
                    printf("Nomor rak tidak valid!\n");
                break;

            case 2:
                printf("\n=== KURANGI STOK ===\n");
                for (int i = 0; i < JUMLAH_RAK; i++) {
                    printf("%d. %s (Stok: %d)\n", i + 1, namaJenisBarang[i], jumlahStok[i]);
                }
                printf("Pilih nomor rak: ");
                scanf("%d", &nomorRak);
                getchar();
                if (nomorRak >= 1 && nomorRak <= JUMLAH_RAK)
                    kurangiStok(jumlahStok, nomorRak - 1);
                else
                    printf("Nomor rak tidak valid!\n");
                break;

            case 3:
                tampilkanHistogram(namaJenisBarang, jumlahStok);
                break;

            case 0:
                printf("Keluar dari sistem inventori...\n");
                break;

            default:
                printf("Pilihan tidak valid!\n");
        }
    } while (pilihan != 0);

    return 0;
}

void tampilkanMenu() {
    printf("\n=== MENU GUDANG ===\n");
    printf("1. Tambah stok barang\n");
    printf("2. Kurangi stok barang\n");
    printf("3. Lihat laporan stok (histogram)\n");
    printf("0. Keluar\n");
}

void tampilkanHistogram(char namaJenisBarang[][MAX_NAMA], int jumlahStok[]) {
    printf("\n=== LAPORAN STOK (HISTOGRAM) ===\n");
    for (int i = 0; i < JUMLAH_RAK; i++) {
        printf("%-15s | ", namaJenisBarang[i]);
        for (int j = 0; j < jumlahStok[i]; j++)
            printf("*");
        printf(" (%d)\n", jumlahStok[i]);
    }
}

void tambahStok(int jumlahStok[], int nomorRak) {
    int tambah;
    printf("Masukkan jumlah stok yang ingin ditambah: ");
    scanf("%d", &tambah);
    if (tambah > 0)
        jumlahStok[nomorRak] += tambah;
    else
        printf("Jumlah tidak boleh negatif!\n");
}

void kurangiStok(int jumlahStok[], int nomorRak){
    int kurang;
    printf("Masukkan jumlah stok yang ingin dikurangi: ");
    scanf("%d", &kurang);
    if (kurang > 0 && jumlahStok[nomorRak] >= kurang)
        jumlahStok[nomorRak] -= kurang;
    else if (kurang > jumlahStok[nomorRak])
        printf("Stok tidak cukup!\n");
    else
        printf("Jumlah tidak valid!\n");
}
